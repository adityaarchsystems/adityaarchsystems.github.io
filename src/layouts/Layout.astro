---
import '../styles/global.css';
import { ClientRouter } from 'astro:transitions';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content="Calyx Sovereign Hub - Institutional Grade Architecture" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- Google Fonts: Orbitron and JetBrains fallback -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Orbitron:wght@400..900&family=JetBrains+Mono:wght@100..800&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <ClientRouter />
    <style>
      @keyframes sonar-pulse {
        0%, 100% { opacity: 0.1; transform: scale(1); }
        50% { opacity: 0.6; transform: scale(1.02); }
      }
      .sonar-grid {
        animation: sonar-pulse 1s cubic-bezier(0.4, 0, 0.6, 1) infinite;
      }
    </style>
  </head>
  <body>
    <!-- Top Command Bar -->
    <nav class="fixed top-0 left-0 w-full h-12 bg-[#16171D] border-b border-white/10 z-[1000] flex justify-between items-center px-6 md:px-12">
      <a href="/" class="font-mono text-[#F2F2F2] text-[11px] font-bold tracking-widest hover:text-[#C8F135] transition-colors uppercase">[CALYX_OS_V5.1]</a>
      <span id="bhilai-clock" class="font-mono text-[#C8F135] text-[11px] font-bold uppercase tracking-widest">--:--:--</span>
    </nav>

    <!-- Interactive Sonar Grid -->
    <div id="interactive-grid" class="fixed inset-0 pointer-events-none z-[1] sonar-grid" style="
      background-image: url('data:image/svg+xml,%3Csvg width=\'40\' height=\'40\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M 40 0 L 0 0 0 40\' fill=\'none\' stroke=\'%23C8F135\' stroke-width=\'1.5\'/%3E%3C/svg%3E'); 
      background-size: 40px 40px; 
      background-attachment: fixed;
      mask-image: radial-gradient(300px circle at var(--mouse-x, -500px) var(--mouse-y, -500px), black 0%, transparent 100%);
      -webkit-mask-image: radial-gradient(300px circle at var(--mouse-x, -500px) var(--mouse-y, -500px), black 0%, transparent 100%);
    "></div>
    
    <script>
      setInterval(() => {
        const clock = document.getElementById('bhilai-clock');
        if (clock) {
          clock.textContent = new Date().toLocaleTimeString('en-US', { timeZone: 'Asia/Kolkata', hour12: false }) + ' IST';
        }
      }, 1000);

      // Global Audio Engine
      let audioCtx = null;
      let humOsc = null;
      let audioInitialized = false;

      window.initAudio = function() {
        if (audioInitialized) return;
        audioInitialized = true;
        const AudioContextClass = window.AudioContext || window.webkitAudioContext;
        if (!AudioContextClass) return;
        
        audioCtx = new AudioContextClass();
        
        // Sovereign Hum
        humOsc = audioCtx.createOscillator();
        humOsc.type = 'sawtooth';
        humOsc.frequency.value = 55;
        
        const humGain = audioCtx.createGain();
        humGain.gain.value = 0.05;
        
        humOsc.connect(humGain);
        humGain.connect(audioCtx.destination);
        humOsc.start();
      };

      window.playBlip = function() {
        if (!audioCtx || audioCtx.state !== 'running') return;
        const osc = audioCtx.createOscillator();
        osc.type = 'square';
        osc.frequency.setValueAtTime(800, audioCtx.currentTime);
        osc.frequency.exponentialRampToValueAtTime(1200, audioCtx.currentTime + 0.05);
        
        const gain = audioCtx.createGain();
        gain.gain.setValueAtTime(0.05, audioCtx.currentTime);
        gain.gain.exponentialRampToValueAtTime(0.001, audioCtx.currentTime + 0.05);
        
        osc.connect(gain);
        gain.connect(audioCtx.destination);
        osc.start();
        osc.stop(audioCtx.currentTime + 0.05);
      };

      document.addEventListener('astro:page-load', () => {
        const grid = document.getElementById('interactive-grid');
        if (grid) {
          document.addEventListener('mousemove', (e) => {
            grid.style.setProperty('--mouse-x', `${e.clientX}px`);
            grid.style.setProperty('--mouse-y', `${e.clientY}px`);
          });
        }
      });
    </script>

    <!-- ASCII Boot Sequence (Handshake Gate) -->
    <div id="boot-sequence" class="fixed inset-0 z-[100000] bg-[#0B0C0E] flex flex-col items-center justify-center transition-all duration-[1500ms]">
      <pre class="font-mono text-[#C8F135] text-[10px] sm:text-xs md:text-sm leading-none tracking-widest font-black text-center mb-12">
   в–€в–€в–€в–€в–€в–€в•— в–€в–€в–€в–€в–€в•— в–€в–€в•—  в–€в–€в•—   в–€в–€в•—в–€в–€в•—  в–€в–€в•—
  в–€в–€в•”в•ђв•ђв•ђв•ђв•ќв–€в–€в•”в•ђв•ђв–€в–€в•—в–€в–€в•‘  в•љв–€в–€в•— в–€в–€в•”в•ќв•љв–€в–€в•—в–€в–€в•”в•ќ
  в–€в–€в•‘     в–€в–€в–€в–€в–€в–€в–€в•‘в–€в–€в•‘   в•љв–€в–€в–€в–€в•”в•ќ  в•љв–€в–€в–€в•”в•ќ 
  в–€в–€в•‘     в–€в–€в•”в•ђв•ђв–€в–€в•‘в–€в–€в•‘    в•љв–€в–€в•”в•ќ   в–€в–€в•”в–€в–€в•— 
  в•љв–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘  в–€в–€в•‘в–€в–€в–€в–€в–€в–€в–€в•—в–€в–€в•‘   в–€в–€в•”в•ќ в–€в–€в•—
   в•љв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ  в•љв•ђв•ќв•љв•ђв•ђв•ђв•ђв•ђв•ђв•ќв•љв•ђв•ќ   в•љв•ђв•ќ  в•љв•ђв•ќ
      </pre>
      <button id="initialize-btn" class="font-sans font-black text-lg tracking-widest uppercase text-[#0B0C0E] bg-[#C8F135] px-8 py-4 hover:bg-[#F2F2F2] hover:scale-105 transition-all duration-200 cursor-crosshair">
        [INITIALIZE_SYSTEM]
      </button>
    </div>
    
    <script>
      document.addEventListener('astro:page-load', () => {
        const boot = document.getElementById('boot-sequence');
        const initBtn = document.getElementById('initialize-btn');
        
        if (sessionStorage.getItem('calyx_initialized') === 'true') {
          if (boot) boot.remove();
          if (window.initAudio) window.initAudio();
        } else if (initBtn && boot) {
          initBtn.addEventListener('click', () => {
            if (window.initAudio) window.initAudio();
            boot.classList.add('opacity-0', 'scale-110', 'pointer-events-none');
            setTimeout(() => boot.remove(), 1500);
            sessionStorage.setItem('calyx_initialized', 'true');
          });
        }
      });
    </script>

    <!-- The Data Stream (Log Feed) -->
    <div id="data-stream" class="fixed bottom-4 left-4 z-[999] font-mono text-[9px] text-[#F2F2F2]/50 leading-tight w-48 h-32 overflow-hidden flex flex-col justify-end pointer-events-none mask-gradient"></div>
    <script>
      setInterval(() => {
        const stream = document.getElementById('data-stream');
        if (stream) {
          const p = document.createElement('p');
          p.textContent = '> 0x' + Math.random().toString(16).substring(2, 10).toUpperCase() + ' // OK';
          stream.appendChild(p);
          if (stream.children.length > 8) stream.firstChild?.remove();
        }
      }, 350);
    </script>

    <!-- Tactical Brutalism V4: Texture Engine -->
    <div class="fixed inset-0 pointer-events-none z-[9999]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%220 0 200 200%22 xmlns=%22http://www.w3.org/2000/svg%22%3E%3Cfilter id=%22noiseFilter%22%3E%3CfeTurbulence type=%22fractalNoise%22 baseFrequency=%220.65%22 numOctaves=%223%22 stitchTiles=%22stitch%22/%3E%3C/filter%3E%3Crect width=%22100%25%22 height=%22100%25%22 filter=%22url(%23noiseFilter)%22/%3E%3C/svg%3E'); opacity: 0.04; mix-blend-mode: overlay;"></div>
    <div class="fixed inset-0 pointer-events-none z-[9999] opacity-[0.08]" style="background: repeating-linear-gradient(0deg, transparent, transparent 2px, rgba(0,0,0,1) 2px, rgba(0,0,0,1) 4px); background-size: 100% 4px;"></div>

    <main class="w-full min-h-screen relative pt-20 pb-32 px-4 md:px-12 flex justify-center">
      <!-- Mecha HUD Armor Frame -->
      <div class="w-full max-w-7xl min-h-[85vh] border border-[#C8F135]/20 bg-[#0B0C0E]/60 relative z-10 transition-all" style="clip-path: polygon(30px 0, 100% 0, 100% calc(100% - 30px), calc(100% - 30px) 100%, 0 100%, 0 30px);">
        <!-- Internal Accents -->
        <div class="absolute top-0 left-0 w-8 h-8 border-t-2 border-l-2 border-[#C8F135] pointer-events-none"></div>
        <div class="absolute bottom-0 right-0 w-8 h-8 border-b-2 border-r-2 border-[#C8F135] pointer-events-none"></div>
        
        <div class="w-full h-full p-8 md:p-12 relative">
          <slot />
        </div>
      </div>
    </main>
    
    <style>
      .mask-gradient {
        mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
        -webkit-mask-image: linear-gradient(to bottom, transparent 0%, black 100%);
      }
    </style>
  </body>
</html>
