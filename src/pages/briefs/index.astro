---
import Layout from '../../layouts/Layout.astro';
import DnaSwitchboard from '../../components/DNA_Switchboard.astro';
import { getCollection } from 'astro:content';

const briefs = await getCollection('briefs');
briefs.sort((a, b) => new Date(b.data.timestamp).valueOf() - new Date(a.data.timestamp).valueOf());
---

<Layout title="CALYX BRIEFS // SOVEREIGN FEED">
  <div class="max-w-4xl mx-auto pt-32 px-8 pb-48">
    <header class="mb-24">
      <h1 class="text-6xl tracking-tighter font-black uppercase text-[#F2F2F2]">
        Sovereign Feed
      </h1>
      <p class="font-mono text-xs opacity-50 mt-4 uppercase">
        Intelligence Architecture // Clinical Audits
      </p>
    </header>

    <div class="grid grid-cols-2 md:grid-cols-8 gap-1 border border-white/5 bg-white/5 p-1 relative z-10">
      {Array.from({ length: 16 }).map((_, i) => {
        const brief = briefs[i];
        return (
          <a 
            href={brief ? `/briefs/${(brief.slug || brief.id).replace(/\.md$/, '')}` : '#'} 
            class="group relative aspect-square bg-[#0B0C0E] border border-transparent flex flex-col items-center justify-center overflow-hidden hover:border-[#C8F135]/30 transition-all duration-300"
            style="clip-path: polygon(50% 0%, 100% 25%, 100% 75%, 50% 100%, 0% 75%, 0% 25%);"
            onmouseenter="if(window.playBlip) window.playBlip()"
          >
            <!-- Wireframe Ghost -->
            <div class="absolute inset-0 opacity-0 group-hover:opacity-100 transition-opacity duration-300 pointer-events-none" style="background-image: linear-gradient(0deg, transparent 24%, rgba(200,241,53,0.1) 25%, rgba(200,241,53,0.1) 26%, transparent 27%, transparent 74%, rgba(200,241,53,0.1) 75%, rgba(200,241,53,0.1) 76%, transparent 77%, transparent), linear-gradient(90deg, transparent 24%, rgba(200,241,53,0.1) 25%, rgba(200,241,53,0.1) 26%, transparent 27%, transparent 74%, rgba(200,241,53,0.1) 75%, rgba(200,241,53,0.1) 76%, transparent 77%, transparent); background-size: 20px 20px;"></div>
            
            <div class="absolute inset-0 border border-[#C8F135]/0 group-hover:border-[#C8F135]/20 scale-95 group-hover:scale-100 transition-all duration-500 pointer-events-none"></div>

            <span class="font-mono text-[9px] text-[#F2F2F2]/30 group-hover:text-[#C8F135] transition-colors relative z-10 tracking-widest">
              {brief ? brief.data.title.substring(0, 4).toUpperCase() : `SEC${(i+1).toString().padStart(2, '0')}`}
            </span>
          </a>
        );
      })}
    </div>
  </div>

  <DnaSwitchboard />
</Layout>
