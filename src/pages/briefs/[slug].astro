---
import Layout from '../../layouts/Layout.astro';
import DnaSwitchboard from '../../components/DNA_Switchboard.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const briefs = await getCollection('briefs');
  return briefs.map(brief => ({
    params: { slug: (brief.slug || brief.id).replace(/\.md$/, '') },
    props: { brief },
  }));
}

const { brief } = Astro.props;
const { Content } = await render(brief);
---

<Layout title={brief.data.title}>
  <div class="max-w-4xl mx-auto pt-32 px-8 pb-48">
    <header class="mb-16 pb-8 border-b border-white/5">
      <div class="flex items-center gap-6 font-mono text-xs text-[#C8F135] uppercase mb-6">
        <time datetime={brief.data.timestamp}>{new Date(brief.data.timestamp).toISOString().split('T')[0]}</time>
        <span>{brief.data.readTime}</span>
      </div>
      <h1 class="text-3xl sm:text-4xl tracking-tighter font-black text-[#F2F2F2]">
        {brief.data.title}
      </h1>
    </header>

    <div class="prose prose-invert prose-p:text-sm prose-p:leading-relaxed prose-p:text-[#F2F2F2]/90 prose-h2:text-xl prose-h2:font-bold prose-h2:tracking-tight prose-h2:text-[#F2F2F2] prose-h2:mt-12 prose-a:text-[#C8F135] prose-li:text-sm prose-li:text-[#F2F2F2]/90 prose-strong:text-[#F2F2F2] max-w-none font-sans">
      <Content />
    </div>
  </div>

  <DnaSwitchboard />
</Layout>
