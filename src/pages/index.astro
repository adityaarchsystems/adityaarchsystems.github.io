---
import Layout from '../layouts/Layout.astro';

const pids = [
  { id: 'PID_001', name: 'FOLIO_BETA', desc: '[GA4_ANALYTICS_DASHBOARD]', link: '/briefs/PID_001' },
  { id: 'PID_002', name: 'CALYX_ARC', desc: '[CLINIC_ORCHESTRATION_&_AUTO_RECEPTION]', link: '/briefs' },
  { id: 'PID_003', name: 'OMNI_AD_VIBE_SPY', desc: '[AD_INTELLIGENCE_RECON]', link: '/briefs' },
  { id: 'PID_004', name: 'CALYX_CONTEXT_TDE', desc: '[TACTICAL_DEV_ENV_CORE]', link: '/briefs' },
  { id: 'PID_005', name: 'CALYX_BRIEFS', desc: '[R&D_DOSSIER_INCL_SHOT2SOCIAL]', link: '/briefs' },
];
---
<Layout title="CALYX COMMAND INTERFACE">
  <div class="w-full min-h-screen flex flex-col justify-center items-start px-12 md:px-32 relative overflow-hidden" transition:animate="fade">
    <div class="fixed top-12 left-12 z-20">
      <h1 class="font-black text-2xl uppercase tracking-[-0.05em] text-[#F2F2F2]">Calyx Studios</h1>
      <p class="font-mono text-xs opacity-50 mt-1 text-[#C8F135]">SYSTEM_MANIFEST_v3.0 // PIDs: ACTIVE</p>
    </div>

    <div class="w-full max-w-4xl font-mono text-sm uppercase flex flex-col relative z-10 border-t border-white/5">
      {pids.map((pid) => (
        <a href={pid.link} class="pid-row block group relative flex items-center justify-between border-b border-white/5 py-8 cursor-crosshair no-underline overflow-hidden" data-pid={pid.id} data-name={pid.name} data-desc={pid.desc} data-link={pid.link}>
          <div class="flex items-center gap-12 relative z-10">
            <span class="text-[#F2F2F2]/30 group-hover:text-[#0B0C0E] transition-colors duration-200">{pid.id}</span>
            <span class="text-[#F2F2F2] font-mono tracking-tight text-xl group-hover:text-[#0B0C0E] font-black transition-colors">{pid.name}</span>
          </div>
          <span class="text-right opacity-30 group-hover:opacity-100 group-hover:text-[#0B0C0E] transition-all duration-300 md:block hidden relative z-10 font-bold">{pid.desc}</span>
          <div class="absolute top-0 left-0 w-full h-full bg-[#C8F135] scale-y-0 origin-bottom group-hover:scale-y-100 transition-transform duration-300 pointer-events-none z-0"></div>
        </a>
      ))}
    </div>

    <!-- Dossier Slide-out Panel -->
    <aside id="dossier-panel" class="fixed top-0 right-0 h-screen w-full md:w-[450px] border-l border-white/10 bg-[#0B0C0E]/95 backdrop-blur-xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.19,1,0.22,1)] z-50 p-6 flex flex-col overflow-x-hidden">
      <div class="w-full h-full border border-white/10 bg-[#16171D] p-8 relative flex flex-col">
        <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'40\' height=\'40\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M 40 0 L 0 0 0 40\' fill=\'none\' stroke=\'rgba(255,255,255,1)\' stroke-width=\'0.5\'/%3E%3C/svg%3E'); background-size: 40px 40px;"></div>
        
        <header class="border-b border-white/10 pb-6 mb-8 mt-12 relative z-10">
          <p id="d-pid" class="font-mono text-sm text-[#C8F135] mb-2">PID_XXX</p>
          <h2 id="d-name" class="font-black text-4xl tracking-tighter uppercase text-[#F2F2F2] break-words">SYSTEM</h2>
        </header>
        
        <div class="flex-1 font-mono text-xs text-[#F2F2F2]/60 uppercase leading-loose relative z-10">
          <p id="d-desc" class="mb-8 p-4 bg-white/5 border border-white/5 text-[#F2F2F2]/90 break-words">[DESC]</p>
          <div class="flex flex-col gap-2">
            <p class="flex justify-between border-b border-white/5 pb-2"><span>Network Status</span><span class="text-[#C8F135]">ONLINE</span></p>
            <p class="flex justify-between border-b border-white/5 pb-2"><span>Clearance</span><span>LEVEL 4</span></p>
            <p class="flex justify-between border-b border-white/5 pb-2"><span>Architecture</span><span>VITE_6_EDGE</span></p>
            <p class="flex justify-between pb-2"><span>Handshake</span><span class="animate-pulse">AWAITING...</span></p>
          </div>
        </div>

        <a id="d-link" href="#" class="block w-full py-4 text-center bg-[#F2F2F2] text-[#0B0C0E] font-black text-sm tracking-widest uppercase hover:bg-[#C8F135] transition-colors relative z-10">
          Execute Handshake
        </a>
      </div>
    </aside>
  </div>

  <script>
    document.addEventListener('astro:page-load', () => {
      const rows = document.querySelectorAll('.pid-row');
      const panel = document.getElementById('dossier-panel');
      const dPid = document.getElementById('d-pid');
      const dName = document.getElementById('d-name');
      const dDesc = document.getElementById('d-desc');
      const dLink = document.getElementById('d-link');

      let timeout: any;

      rows.forEach(row => {
        row.addEventListener('mouseenter', () => {
          clearTimeout(timeout);
          const target = row as HTMLElement;
          const { pid, name, desc, link } = target.dataset;
          
          if(dPid) dPid.textContent = pid || '';
          if(dName) dName.textContent = name || '';
          if(dDesc) dDesc.textContent = desc || '';
          if(dLink) dLink.setAttribute('href', link || '#');
          
          panel?.classList.remove('translate-x-full');
        });
        
        row.addEventListener('mouseleave', () => {
          timeout = setTimeout(() => {
            panel?.classList.add('translate-x-full');
          }, 150);
        });
      });

      panel?.addEventListener('mouseenter', () => clearTimeout(timeout));
      panel?.addEventListener('mouseleave', () => panel.classList.add('translate-x-full'));
    });
  </script>
</Layout>
