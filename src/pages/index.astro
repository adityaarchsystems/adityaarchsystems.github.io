---
import Layout from '../layouts/Layout.astro';

const pids = [
  { id: 'PID_001', name: 'FOLIO_BETA', desc: '[GA4_ANALYTICS_DASHBOARD]', link: '/briefs/PID_001' },
  { id: 'PID_002', name: 'CALYX_ARC', desc: '[CLINIC_AUTO_ORCHESTRATION]', link: '/briefs/PID_002' },
  { id: 'PID_003', name: 'OMNI_AD_VIBE_SPY', desc: '[AD_INTELLIGENCE_RECON]', link: '/briefs/PID_003' },
  { id: 'PID_004', name: 'CALYX_CONTEXT_TDE', desc: '[TACTICAL_DEV_ENV_CORE]', link: '/briefs/PID_004' },
  { id: 'PID_005', name: 'CALYX_BRIEFS', desc: '[R&D_DOSSIER_INCL_S2S]', link: '/briefs/PID_005' },
];
---
<Layout title="CALYX COMMAND INTERFACE - APEX V4">
  <!-- Removed Interactive Grid Base (Now in Layout.astro) -->

  <!-- Live Coordinate Tracker -->
  <div id="coord-hud" class="fixed top-12 right-12 font-mono text-[11px] text-[#C8F135] z-50 uppercase tracking-widest">
    [X:0000 Y:0000]
  </div>

  <div class="w-full min-h-screen flex flex-col justify-center items-start px-12 md:px-32 relative overflow-hidden" transition:animate="fade">
    <div class="fixed top-12 left-12 z-20">
      <h1 class="font-sans font-black text-2xl uppercase tracking-[-0.07em] text-[#F2F2F2] chromatic-text">Calyx Studios</h1>
      <p class="font-mono text-[11px] opacity-50 mt-1 text-[#C8F135] uppercase">V5.0_APEX_TOTAL_DOMINATION // PIDs: ACTIVE</p>
    </div>

    <div class="w-full max-w-4xl font-mono uppercase flex flex-col relative z-10 border-t border-white/5">
      {pids.map((pid) => (
        <a href={pid.link} class="pid-row block group relative flex items-center justify-between border-b border-white/5 py-8 cursor-crosshair no-underline overflow-hidden hover-glitch" data-pid={pid.id} data-name={pid.name} data-desc={pid.desc} data-link={pid.link}>
          <div class="flex items-center gap-12 relative z-10 glitch-target">
            <span class="text-[#F2F2F2]/30 group-hover:text-[#0B0C0E] transition-colors duration-200 text-[11px] uppercase">{pid.id}</span>
            <span class="text-[#F2F2F2] font-mono tracking-tight text-xl group-hover:text-[#0B0C0E] font-black transition-colors uppercase">{pid.name}</span>
          </div>
          <span class="text-right opacity-30 group-hover:opacity-100 group-hover:text-[#0B0C0E] transition-all duration-300 md:block hidden relative z-10 font-bold text-[11px] uppercase glitch-target">{pid.desc}</span>
          <div class="absolute top-0 left-0 w-full h-full bg-[#C8F135] opacity-0 group-hover:opacity-100 transition-opacity duration-75 pointer-events-none z-0"></div>
        </a>
      ))}
    </div>

    <!-- Dossier Slide-out Panel -->
    <aside id="dossier-panel" class="fixed top-0 right-0 h-screen w-full md:w-[450px] border-l border-white/10 bg-[#0B0C0E]/95 backdrop-blur-xl transform translate-x-full transition-transform duration-500 ease-[cubic-bezier(0.175,0.885,0.32,1.275)] z-50 p-6 flex flex-col overflow-x-hidden" style="clip-path: polygon(20px 0, calc(100% - 20px) 0, 100% 20px, 100% calc(100% - 20px), calc(100% - 20px) 100%, 20px 100%, 0 calc(100% - 20px), 0 20px);">
      <div class="w-full h-full border border-white/10 bg-[#16171D] p-8 relative flex flex-col">
        <div class="absolute inset-0 pointer-events-none opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg width=\'40\' height=\'40\' xmlns=\'http://www.w3.org/2000/svg\'%3E%3Cpath d=\'M 40 0 L 0 0 0 40\' fill=\'none\' stroke=\'rgba(255,255,255,1)\' stroke-width=\'0.5\'/%3E%3C/svg%3E'); background-size: 40px 40px;"></div>
        
        <header class="border-b border-white/10 pb-6 mb-8 mt-12 relative z-10">
          <p id="d-pid" class="font-mono text-[11px] text-[#C8F135] mb-2 uppercase">PID_XXX</p>
          <h2 id="d-name" class="font-sans font-black text-4xl tracking-tighter uppercase text-[#F2F2F2] break-words chromatic-text">SYSTEM</h2>
        </header>
        
        <div class="flex-1 font-mono text-[11px] text-[#F2F2F2]/60 uppercase leading-loose relative z-10">
          <p id="d-desc" class="mb-8 p-4 bg-white/5 border border-white/5 text-[#F2F2F2]/90 break-words uppercase">[DESC]</p>
          <div class="flex flex-col gap-2">
            <p class="flex justify-between border-b border-white/5 pb-2"><span>NETWORK STATUS</span><span class="text-[#C8F135]">ONLINE</span></p>
            <p class="flex justify-between border-b border-white/5 pb-2"><span>CLEARANCE</span><span>LEVEL 4</span></p>
            <p class="flex justify-between border-b border-white/5 pb-2"><span>ARCHITECTURE</span><span>VITE_6_EDGE</span></p>
            <p class="flex justify-between pb-2"><span>HANDSHAKE</span><span class="animate-pulse">AWAITING...</span></p>
          </div>
        </div>

        <a id="d-link" href="#" class="block w-full py-4 text-center bg-[#F2F2F2] text-[#0B0C0E] font-black text-sm tracking-widest uppercase hover:bg-[#C8F135] transition-colors relative z-10 phosphor-glow transition-all">
          <span class="typing-anim">EXECUTE HANDSHAKE</span>
        </a>
      </div>
    </aside>
  </div>

  <style>
    .typing-anim {
      display: inline-block;
      overflow: hidden;
      white-space: nowrap;
      border-right: 2px solid transparent;
    }
    #d-link:hover .typing-anim {
      animation: typing-stagger 0.2s steps(4, end), blink-caret 0.5s step-end infinite alternate;
      border-right-color: #0B0C0E;
    }
    @keyframes blink-caret { 50% { border-color: transparent } }
  </style>

  <script>
    document.addEventListener('astro:page-load', () => {
      // Audio Handshake on Execute Handshake click
      const initAudioHandler = (e: Event) => {
        if (window.initAudio) window.initAudio();
      };
      
      const handshakeBtn = document.getElementById('d-link');
      if (handshakeBtn) {
        handshakeBtn.addEventListener('click', initAudioHandler);
      }

      const hud = document.getElementById('coord-hud');
      
      document.addEventListener('mousemove', (e) => {
        const x = e.clientX;
        const y = e.clientY;
        if (hud) {
          hud.textContent = `[X:${String(x).padStart(4,'0')} Y:${String(y).padStart(4,'0')}]`;
        }
      });

      const rows = document.querySelectorAll('.pid-row');
      const panel = document.getElementById('dossier-panel');
      const dPid = document.getElementById('d-pid');
      const dName = document.getElementById('d-name');
      const dDesc = document.getElementById('d-desc');
      const dLink = document.getElementById('d-link');

      let timeout: any;

      rows.forEach(row => {
        row.addEventListener('mouseenter', () => {
          if (window.playBlip) window.playBlip();
          clearTimeout(timeout);
          const target = row as HTMLElement;
          const { pid, name, desc, link } = target.dataset;
          
          if(dPid) dPid.textContent = pid || '';
          if(dName) dName.textContent = name || '';
          if(dDesc) dDesc.textContent = desc || '';
          if(dLink) dLink.setAttribute('href', link || '#');
          
          panel?.classList.remove('translate-x-full');
        });
        
        row.addEventListener('mouseleave', () => {
          timeout = setTimeout(() => {
            panel?.classList.add('translate-x-full');
          }, 150);
        });
      });

      panel?.addEventListener('mouseenter', () => clearTimeout(timeout));
      panel?.addEventListener('mouseleave', () => panel.classList.add('translate-x-full'));
    });
  </script>
</Layout>
